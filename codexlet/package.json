{
  "name": "codexlet",
  "version": "1.0.0",
  "description": "Desktop GUI (Electron) wrapper around codelet CLI machine mode",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp -r src/public/* dist/public/",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --inspect",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "server": "npm run build && node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "io.github.xhyccc.codexlet",
    "productName": "codexlet",
    "copyright": "Copyright © 2025",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
