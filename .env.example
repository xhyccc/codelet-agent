# ------------------------------------------------------------------------------
# LLM provider  (used by mini_coding_agent backend; opencode uses its own config)
# ------------------------------------------------------------------------------
# Supported values: kimi | moonshot | zhipu | glm | siliconflow | deepseek |
#                   openrouter | together | dashscope | openai | custom
#
# "kimi" and "moonshot" are aliases - both point to https://api.moonshot.cn/v1
# "zhipu" and "glm" are aliases    - both point to Zhipu / BigModel
# "custom" requires LLM_BASE_URL + LLM_API_KEY + LLM_MODEL to be set below.
# ------------------------------------------------------------------------------
LLM_PROVIDER=kimi


# ------------------------------------------------------------------------------
# API keys - set the one matching your provider
# ------------------------------------------------------------------------------

# Kimi / Moonshot AI  (https://platform.moonshot.cn)
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # alias

# Zhipu AI / GLM  (https://open.bigmodel.cn)
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxx

# SiliconFlow  (https://siliconflow.cn)
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI  (https://platform.openai.com)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Generic override - takes priority over all provider-specific keys above
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------------------------
# Model selection
# ------------------------------------------------------------------------------
# Leave blank to use the provider default, or set an explicit name.
#
#   kimi / moonshot : moonshot-v1-8k (default) | moonshot-v1-32k | moonshot-v1-128k
#   zhipu / glm     : glm-4-flash (default) | glm-4 | glm-4-long
#   siliconflow     : Qwen/Qwen2.5-7B-Instruct (default) | deepseek-ai/DeepSeek-V3
#   openai          : gpt-4o-mini (default) | gpt-4o | gpt-4-turbo
# ------------------------------------------------------------------------------
# LLM_MODEL=moonshot-v1-128k


# ------------------------------------------------------------------------------
# Custom provider  (only required when LLM_PROVIDER=custom)
# ------------------------------------------------------------------------------
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=your-model-name


# ------------------------------------------------------------------------------
# mini-coding-agent settings
# ------------------------------------------------------------------------------
# Command used to launch mini-coding-agent. Options:
#   mini-coding-agent              if installed via: pip install / uv tool install
#   uv run mini-coding-agent       if using uv without a global install
#   python -m mini_coding_agent    if running from a checkout
# MINI_AGENT_CMD=mini-coding-agent

# Maximum steps (tool calls + model turns) per agent invocation.
# Increase for complex tasks; decrease for faster/cheaper runs.
MINI_AGENT_MAX_STEPS=15
MINI_AGENT_MAX_NEW_TOKENS=8192
# Default timeout for run_shell / run_python tool calls (seconds).
# The model may request a lower value; it is clamped to MINI_AGENT_TOOL_MAX_TIMEOUT.
MINI_AGENT_TOOL_TIMEOUT=60
MINI_AGENT_TOOL_MAX_TIMEOUT=300

